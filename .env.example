# PHISGUARD Configuration
# Copy this file to .env and fill in all values marked as REQUIRED

# ============================================================================
# AUTHENTICATION (REQUIRED - app will not start without these)
# ============================================================================
# Admin login password (create a strong value, e.g. generate with: python -c "import secrets; print(secrets.token_urlsafe(16))")
ADMIN_PASSWORD=set_a_strong_admin_password_here

# User login password (all users share this password; create a strong value)
USER_PASSWORD=set_a_strong_user_password_here

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=set_a_strong_secret_key_here

# ============================================================================
# DATABASE (Optional - defaults to SQLite)
# ============================================================================
# DATABASE_URL=sqlite:///app.db

# ============================================================================
# OUTBOUND EMAIL (Optional - for sending simulation emails to external users)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=youraddress@gmail.com
# SMTP_PASSWORD=your_app_password_here
# SMTP_FROM_EMAIL=youraddress@gmail.com

# ============================================================================
# DEPLOYMENT (Optional - for production URL in email links)
# ============================================================================
# FLASK_BASE_URL=https://your-public-hostname-or-tunnel
